{
  "name": "@shabalinmax/tiptap-scout",
  "version": "0.1.1",
  "description": "Search and replace extension for Tiptap",
  "author": "shabalinmax",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/pm": "^3.0.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "jsdom": "^28.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "tiptap",
    "search",
    "replace",
    "find",
    "prosemirror",
    "extension"
  ]
}
