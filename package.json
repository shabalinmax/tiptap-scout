{
  "name": "@shabalinmax/tiptap-scout",
  "version": "0.4.3",
  "description": "Search and replace extension for Tiptap",
  "author": "shabalinmax",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tiptap/core": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/react": "^19.2.14",
    "jsdom": "^28.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://github.com/shabalinmax/tiptap-scout#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/shabalinmax/tiptap-scout.git"
  },
  "bugs": {
    "url": "https://github.com/shabalinmax/tiptap-scout/issues"
  },
  "keywords": [
    "tiptap",
    "search",
    "replace",
    "find",
    "prosemirror",
    "extension"
  ]
}
